# Binance Spot TESTNET API credentials.
# Generate a key pair at https://testnet.binance.vision/ (log in with GitHub).
# Copy this file to `.env` and fill in the values. `.env` is gitignored and must
# NEVER be committed (golden rule #1). Keys are only needed from Phase 5 onward.
BINANCE_TESTNET_API_KEY=
